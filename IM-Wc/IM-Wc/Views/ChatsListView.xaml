<UserControl
    x:Class="IM_Wc.Views.ChatsListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:IM_Wc.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="910" xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    d:DesignWidth="250" xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    mc:Ignorable="d" Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel VerticalAlignment="Center" >

            <Button mah:ControlsHelper.CornerRadius="5"
                Content="{iconPacks:Fontisto Kind=PlusA,Height=10,Width=10}" Padding="1"
Background="#d3d3d3"
                Margin="5" Height="30" Width="30"
                DockPanel.Dock="Right"
                Style="{StaticResource MahApps.Styles.Button.ToolBar}" />
            <TextBox mah:ControlsHelper.CornerRadius="5" Margin="5" mah:TextBoxHelper.Watermark="Search" Background="#f3f3f3"/>
        </DockPanel>
        <ListBox Grid.Row="1" Background="#f3f3f3"/>
    </Grid>
</UserControl>
